{
  "expo": {
    "name": "منصة المسار الأدبي",
    "slug": "literary-track-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "literarytrack",
    "extra": {
      "convexUrl": "https://successful-panda-576.convex.cloud"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E4F4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "منصة قسم المسار الأدبي",
      "shortName": "المسار الأدبي",
      "lang": "ar",
      "dir": "rtl",
      "display": "standalone",
      "orientation": "portrait",
      "themeColor": "#5C1523",
      "backgroundColor": "#FCF9F2",
      "description": "منصة إدارة قسم المسار الأدبي — مدرسة النهضة الابتدائية للبنات",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-sharing",
      "expo-font"
    ]
  }
}
